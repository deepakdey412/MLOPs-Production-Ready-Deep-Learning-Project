pipeline {
    agent any

    environment {
        ECR_REPOSITORY = credentials('ECR_REPOSITORY')
        AWS_ACCOUNT_ID = credentials('AWS_ACCOUNT_ID')
        AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
    }

    stages {

        stage('Continuous Integration') {
            steps {
                script {
                    echo "Linting repository"
                    echo "Running unit tests"
                }
            }
        }

        stage('Login to ECR') {
            steps {
                script {
                    // ✅ Region corrected to ap-south-1, hardcoded ECR URI
                    sh '''
                    aws ecr get-login-password --region ap-south-1 | \
                    docker login --username AWS --password-stdin 032552344224.dkr.ecr.ap-south-1.amazonaws.com
                    '''
                }
            }
        }

        stage('Build Image') {
            steps {
                script {
                    // ✅ Hardcoded full ECR repo URI
                    sh '''
                    docker build -t 032552344224.dkr.ecr.ap-south-1.amazonaws.com/sign-lang:latest .
                    '''
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    // ✅ Push using same full ECR URI
                    sh '''
                    docker push 032552344224.dkr.ecr.ap-south-1.amazonaws.com/sign-lang:latest
                    '''
                }
            }
        }

        stage('Continuous Deployment') {
            steps {
                sshagent(['ssh_key']) {
                    sh """
                    ssh -o StrictHostKeyChecking=no -l ubuntu 13.126.146.4 '
                    
                    # ✅ Go to home directory
                    cd /home/ubuntu/

                    # ✅ Download docker-compose file
                    wget -O docker-compose.yml https://raw.githubusercontent.com/entbappy/Chest-Disease-Classification-from-Chest-CT-Scan-Image/main/docker-compose.yml

                    # ✅ Set image name (hardcoded)
                    export IMAGE_NAME=032552344224.dkr.ecr.ap-south-1.amazonaws.com/sign-lang:latest

                    # ✅ Login to ECR from EC2
                    aws ecr get-login-password --region ap-south-1 | \
                    docker login --username AWS --password-stdin 032552344224.dkr.ecr.ap-south-1.amazonaws.com

                    # ✅ Run container
                    docker compose up -d
                    '
                    """
                }
            }
        }

    }

    post {
        always {
            // ✅ Cleanup Docker
            sh 'docker system prune -f'
        }
    }
}